{
  "$id": "https://circle-calculus.local/schemas/circle_ai_contract_artifact_manifest_file_check.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "failure_count": {
      "minimum": 0,
      "type": "integer"
    },
    "failures": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "manifest_count": {
      "minimum": 0,
      "type": "integer"
    },
    "ok": {
      "type": "boolean"
    },
    "schema_id": {
      "const": "circle_calculus.ai_contract_artifact_manifest_file_check.v0"
    },
    "summaries": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "artifact_count": {
            "minimum": 0,
            "type": "integer"
          },
          "artifact_dir": {
            "type": [
              "string",
              "null"
            ]
          },
          "artifact_fingerprint_algorithm": {
            "const": "sha256-file-v1"
          },
          "artifact_prefix": {
            "minLength": 1,
            "type": "string"
          },
          "artifacts": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "actual_schema_id": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "actual_sha256": {
                  "anyOf": [
                    {
                      "pattern": "^[0-9a-f]{64}$",
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "content_schema_id": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "declared_exists": {
                  "type": "boolean"
                },
                "declared_sha256": {
                  "anyOf": [
                    {
                      "pattern": "^[0-9a-f]{64}$",
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "exists": {
                  "type": "boolean"
                },
                "failures": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "label": {
                  "minLength": 1,
                  "type": "string"
                },
                "ok": {
                  "type": "boolean"
                },
                "path": {
                  "minLength": 1,
                  "type": "string"
                },
                "resolved_path": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "required": [
                "label",
                "path",
                "resolved_path",
                "exists",
                "declared_exists",
                "declared_sha256",
                "actual_sha256",
                "content_schema_id",
                "actual_schema_id",
                "ok",
                "failures"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "decision_assurance": {
            "enum": [
              "theorem_backed",
              "mixed_theorem_and_computation",
              "numerical_only",
              "unsupported",
              "undecided",
              null
            ],
            "type": [
              "string",
              "null"
            ]
          },
          "decision_verdict": {
            "enum": [
              "passed",
              "failed",
              "undecided",
              "numerical_only",
              "outside_scope",
              null
            ],
            "type": [
              "string",
              "null"
            ]
          },
          "declared_artifact_count": {
            "minimum": 0,
            "type": "integer"
          },
          "evidence_field_count": {
            "minimum": 0,
            "type": "integer"
          },
          "evidence_fields": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "failure_count": {
            "minimum": 0,
            "type": "integer"
          },
          "fingerprint_mismatch_count": {
            "minimum": 0,
            "type": "integer"
          },
          "gate_policy": {
            "additionalProperties": false,
            "properties": {
              "allowed_assurance_levels": {
                "items": {
                  "enum": [
                    "theorem_backed",
                    "mixed_theorem_and_computation",
                    "numerical_only",
                    "unsupported",
                    "undecided"
                  ]
                },
                "type": "array"
              },
              "allowed_decision_verdicts": {
                "items": {
                  "enum": [
                    "passed",
                    "failed",
                    "undecided",
                    "numerical_only",
                    "outside_scope"
                  ]
                },
                "type": "array"
              },
              "allowed_statuses": {
                "items": {
                  "enum": [
                    "proved",
                    "impossible",
                    "undecided",
                    "numerical_only",
                    "outside_scope"
                  ]
                },
                "type": "array"
              },
              "require_passed": {
                "type": "boolean"
              }
            },
            "required": [
              "allowed_statuses",
              "allowed_decision_verdicts",
              "allowed_assurance_levels",
              "require_passed"
            ],
            "type": "object"
          },
          "kind": {
            "enum": [
              "rope_position_distinguishability",
              "kv_cache_ring_buffer",
              "sparse_attention_coverage",
              "recurrence_schedule",
              null
            ],
            "type": [
              "string",
              "null"
            ]
          },
          "missing_artifact_count": {
            "minimum": 0,
            "type": "integer"
          },
          "normalized_request": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ]
          },
          "normalized_request_fingerprint": {
            "anyOf": [
              {
                "pattern": "^[0-9a-f]{64}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "receipt_content_fingerprint": {
            "anyOf": [
              {
                "pattern": "^[0-9a-f]{64}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "recommendation_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "request_content_fingerprint": {
            "anyOf": [
              {
                "pattern": "^[0-9a-f]{64}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "request_passed": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "schema_mismatch_count": {
            "minimum": 0,
            "type": "integer"
          },
          "status": {
            "enum": [
              "proved",
              "impossible",
              "undecided",
              "numerical_only",
              "outside_scope",
              null
            ],
            "type": [
              "string",
              "null"
            ]
          },
          "theorem_count": {
            "minimum": 0,
            "type": "integer"
          },
          "theorem_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "validation_command_count": {
            "minimum": 0,
            "type": "integer"
          },
          "validation_commands": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "path",
          "kind",
          "status",
          "request_passed",
          "decision_verdict",
          "decision_assurance",
          "artifact_fingerprint_algorithm",
          "artifact_count",
          "declared_artifact_count",
          "missing_artifact_count",
          "fingerprint_mismatch_count",
          "schema_mismatch_count",
          "artifact_prefix",
          "artifact_dir",
          "gate_policy",
          "normalized_request",
          "request_content_fingerprint",
          "normalized_request_fingerprint",
          "receipt_content_fingerprint",
          "theorem_count",
          "theorem_ids",
          "evidence_field_count",
          "evidence_fields",
          "recommendation_ids",
          "validation_command_count",
          "validation_commands",
          "artifacts",
          "failure_count"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_id",
    "ok",
    "manifest_count",
    "failure_count",
    "failures",
    "summaries"
  ],
  "title": "Circle AI Contract Artifact Manifest File Check Report",
  "type": "object"
}
