{
  "$id": "https://circle-calculus.local/schemas/circle_ai_contract_receipt_file_check.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "failure_count": {
      "minimum": 0,
      "type": "integer"
    },
    "failures": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "gate_policy": {
      "additionalProperties": false,
      "properties": {
        "allowed_assurance_levels": {
          "items": {
            "enum": [
              "theorem_backed",
              "mixed_theorem_and_computation",
              "numerical_only",
              "unsupported",
              "undecided"
            ]
          },
          "type": "array"
        },
        "allowed_decision_verdicts": {
          "items": {
            "enum": [
              "passed",
              "failed",
              "undecided",
              "numerical_only",
              "outside_scope"
            ]
          },
          "type": "array"
        },
        "allowed_statuses": {
          "items": {
            "enum": [
              "proved",
              "impossible",
              "undecided",
              "numerical_only",
              "outside_scope"
            ]
          },
          "type": "array"
        },
        "require_passed": {
          "type": "boolean"
        }
      },
      "required": [
        "allowed_statuses",
        "allowed_decision_verdicts",
        "allowed_assurance_levels",
        "require_passed"
      ],
      "type": "object"
    },
    "ok": {
      "type": "boolean"
    },
    "receipt_count": {
      "minimum": 0,
      "type": "integer"
    },
    "schema_id": {
      "const": "circle_calculus.ai_contract_receipt_file_check.v0"
    },
    "summaries": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "content_fingerprint_algorithm": {
            "const": "sha256-json-v1"
          },
          "contract_content_fingerprint": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "contract_id": {
            "minLength": 1,
            "type": "string"
          },
          "contract_pack_fingerprint": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "decision_assurance": {
            "enum": [
              "theorem_backed",
              "mixed_theorem_and_computation",
              "numerical_only",
              "unsupported",
              "undecided"
            ]
          },
          "decision_verdict": {
            "enum": [
              "passed",
              "failed",
              "undecided",
              "numerical_only",
              "outside_scope"
            ]
          },
          "failure_count": {
            "minimum": 0,
            "type": "integer"
          },
          "kind": {
            "enum": [
              "rope_position_distinguishability",
              "kv_cache_ring_buffer",
              "sparse_attention_coverage",
              "recurrence_schedule"
            ]
          },
          "normalized_request": {
            "minProperties": 1,
            "type": "object"
          },
          "normalized_request_fingerprint": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "receipt_content_fingerprint": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "request_content_fingerprint": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "request_passed": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "status": {
            "enum": [
              "proved",
              "impossible",
              "undecided",
              "numerical_only",
              "outside_scope"
            ]
          },
          "theorem_count": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "path",
          "kind",
          "contract_id",
          "content_fingerprint_algorithm",
          "contract_pack_fingerprint",
          "contract_content_fingerprint",
          "status",
          "request_passed",
          "decision_verdict",
          "decision_assurance",
          "theorem_count",
          "normalized_request",
          "request_content_fingerprint",
          "normalized_request_fingerprint",
          "receipt_content_fingerprint",
          "failure_count"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_id",
    "ok",
    "receipt_count",
    "failure_count",
    "failures",
    "gate_policy",
    "summaries"
  ],
  "title": "Circle AI Contract Receipt File Check Report",
  "type": "object"
}
