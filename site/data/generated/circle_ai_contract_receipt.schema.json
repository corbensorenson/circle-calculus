{
  "$id": "https://circle-calculus.local/schemas/circle_ai_contract_receipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "content_fingerprint_algorithm": {
      "const": "sha256-json-v1"
    },
    "contract_id": {
      "minLength": 1,
      "type": "string"
    },
    "contract_pack_schema_id": {
      "const": "circle_calculus.ai_contract_pack.v0"
    },
    "evidence": {
      "type": "object"
    },
    "kind": {
      "enum": [
        "rope_position_distinguishability",
        "kv_cache_ring_buffer",
        "sparse_attention_coverage",
        "recurrence_schedule"
      ]
    },
    "normalized_request": {
      "type": "object"
    },
    "normalized_request_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "not_claimed": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "proof_layers": {
      "additionalProperties": true,
      "properties": {
        "computed_fields": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "numerical_only_fields": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "proved_fields": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "unsupported_fields": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "proved_fields",
        "computed_fields",
        "numerical_only_fields",
        "unsupported_fields"
      ],
      "type": "object"
    },
    "proof_status": {
      "additionalProperties": true,
      "properties": {
        "all_theorem_ids_proved": {
          "type": "boolean"
        },
        "all_theorem_ids_resolved": {
          "type": "boolean"
        },
        "theorem_count": {
          "minimum": 0,
          "type": "integer"
        },
        "theorem_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "unproved_theorem_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "unresolved_theorem_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "theorem_ids",
        "theorem_count",
        "all_theorem_ids_resolved",
        "all_theorem_ids_proved",
        "unresolved_theorem_ids",
        "unproved_theorem_ids"
      ],
      "type": "object"
    },
    "receipt_content_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "recommendations": {
      "items": {
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "request": {
      "additionalProperties": false,
      "oneOf": [
        {
          "properties": {
            "kind": {
              "enum": [
                "rope",
                "rope_position_distinguishability"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "base": {
                  "exclusiveMinimum": 0,
                  "type": "number"
                },
                "context": {
                  "minimum": 1,
                  "type": "integer"
                },
                "discretization": {
                  "enum": [
                    "round",
                    "floor",
                    "ceil"
                  ]
                },
                "head_dim": {
                  "minimum": 1,
                  "type": "integer"
                },
                "requested_margin": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "tolerance": {
                  "minimum": 0,
                  "type": "number"
                }
              },
              "type": "object"
            }
          }
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "kv",
                "kv-cache",
                "kv_cache",
                "kv_cache_ring_buffer"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "batch_tokens": {
                  "items": {
                    "type": "integer"
                  },
                  "type": "array"
                },
                "cache_size": {
                  "minimum": 1,
                  "type": "integer"
                },
                "current": {
                  "minimum": 0,
                  "type": "integer"
                },
                "request_id": {
                  "minLength": 1,
                  "type": "string"
                },
                "sink_size": {
                  "minimum": 0,
                  "type": "integer"
                },
                "token": {
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "required": [
                "cache_size",
                "current",
                "token"
              ],
              "type": "object"
            }
          }
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "sparse",
                "sparse-attention",
                "sparse_attention",
                "sparse_attention_coverage"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "context": {
                  "minimum": 1,
                  "type": "integer"
                },
                "local_window": {
                  "minimum": 0,
                  "type": "integer"
                },
                "path_length": {
                  "minimum": 0,
                  "type": "integer"
                },
                "strides": {
                  "items": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "minItems": 1,
                  "type": "array"
                }
              },
              "required": [
                "context",
                "strides",
                "path_length",
                "local_window"
              ],
              "type": "object"
            }
          }
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "recurrence",
                "recurrence-schedule",
                "recurrence_schedule"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "loop_period": {
                  "minimum": 1,
                  "type": "integer"
                },
                "max_loops": {
                  "minimum": 0,
                  "type": "integer"
                },
                "sample_index": {
                  "minimum": 0,
                  "type": "integer"
                },
                "selected_block_start": {
                  "minimum": 0,
                  "type": "integer"
                },
                "selected_block_width": {
                  "minimum": 0,
                  "type": "integer"
                },
                "shift_passes": {
                  "minimum": 0,
                  "type": "integer"
                },
                "token_count": {
                  "minimum": 1,
                  "type": "integer"
                }
              },
              "type": "object"
            }
          }
        }
      ],
      "properties": {
        "kind": {
          "enum": [
            "kv",
            "kv-cache",
            "kv_cache",
            "kv_cache_ring_buffer",
            "recurrence",
            "recurrence-schedule",
            "recurrence_schedule",
            "rope",
            "rope_position_distinguishability",
            "sparse",
            "sparse-attention",
            "sparse_attention",
            "sparse_attention_coverage"
          ]
        },
        "parameters": {
          "minProperties": 0,
          "type": "object"
        },
        "schema_id": {
          "const": "circle_calculus.ai_contract_request.v0"
        }
      },
      "required": [
        "schema_id",
        "kind",
        "parameters"
      ],
      "type": "object"
    },
    "request_content_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "request_passed": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "request_schema_id": {
      "const": "circle_calculus.ai_contract_request.v0"
    },
    "schema_id": {
      "const": "circle_calculus.ai_contract_receipt.v0"
    },
    "status": {
      "enum": [
        "proved",
        "impossible",
        "undecided",
        "numerical_only",
        "outside_scope"
      ]
    },
    "support": {
      "type": "object"
    },
    "validation_commands": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "schema_id",
    "request_schema_id",
    "contract_pack_schema_id",
    "kind",
    "contract_id",
    "status",
    "request_passed",
    "request",
    "request_content_fingerprint",
    "normalized_request",
    "normalized_request_fingerprint",
    "evidence",
    "proof_status",
    "proof_layers",
    "recommendations",
    "validation_commands",
    "support",
    "not_claimed",
    "content_fingerprint_algorithm",
    "receipt_content_fingerprint"
  ],
  "title": "Circle AI Contract Receipt",
  "type": "object"
}
