{
  "$id": "https://circle-calculus.local/schemas/circle_ai_contract_receipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "content_fingerprint_algorithm": {
      "const": "sha256-json-v1"
    },
    "contract_id": {
      "minLength": 1,
      "type": "string"
    },
    "contract_pack_schema_id": {
      "const": "circle_calculus.ai_contract_pack.v0"
    },
    "decision": {
      "additionalProperties": false,
      "properties": {
        "all_theorem_ids_proved": {
          "type": "boolean"
        },
        "assurance": {
          "enum": [
            "theorem_backed",
            "mixed_theorem_and_computation",
            "numerical_only",
            "unsupported",
            "undecided"
          ]
        },
        "claim_status": {
          "enum": [
            "proved",
            "impossible",
            "undecided",
            "numerical_only",
            "outside_scope"
          ]
        },
        "next_action": {
          "minLength": 1,
          "type": "string"
        },
        "proof_layer_counts": {
          "additionalProperties": false,
          "properties": {
            "computed_fields": {
              "minimum": 0,
              "type": "integer"
            },
            "numerical_only_fields": {
              "minimum": 0,
              "type": "integer"
            },
            "proved_fields": {
              "minimum": 0,
              "type": "integer"
            },
            "unsupported_fields": {
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "proved_fields",
            "computed_fields",
            "numerical_only_fields",
            "unsupported_fields"
          ],
          "type": "object"
        },
        "request_passed": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "schema_id": {
          "const": "circle_calculus.ai_contract_decision.v0"
        },
        "summary": {
          "minLength": 1,
          "type": "string"
        },
        "theorem_count": {
          "minimum": 0,
          "type": "integer"
        },
        "verdict": {
          "enum": [
            "passed",
            "failed",
            "undecided",
            "numerical_only",
            "outside_scope"
          ]
        }
      },
      "required": [
        "schema_id",
        "verdict",
        "assurance",
        "claim_status",
        "request_passed",
        "theorem_count",
        "all_theorem_ids_proved",
        "proof_layer_counts",
        "summary",
        "next_action"
      ],
      "type": "object"
    },
    "evidence": {
      "type": "object"
    },
    "kind": {
      "enum": [
        "rope_position_distinguishability",
        "kv_cache_ring_buffer",
        "sparse_attention_coverage",
        "recurrence_schedule",
        "strided_candidate_fanout",
        "cyclic_memory_residue_winding",
        "multicoil_phase_feature",
        "circulant_block_cyclic_mixer",
        "seed_rule_exact_regeneration"
      ]
    },
    "normalized_request": {
      "type": "object"
    },
    "normalized_request_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "not_claimed": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "proof_layers": {
      "additionalProperties": true,
      "properties": {
        "computed_fields": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "numerical_only_fields": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "proved_fields": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "unsupported_fields": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "proved_fields",
        "computed_fields",
        "numerical_only_fields",
        "unsupported_fields"
      ],
      "type": "object"
    },
    "proof_status": {
      "additionalProperties": true,
      "properties": {
        "all_theorem_ids_proved": {
          "type": "boolean"
        },
        "all_theorem_ids_resolved": {
          "type": "boolean"
        },
        "theorem_count": {
          "minimum": 0,
          "type": "integer"
        },
        "theorem_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "unproved_theorem_ids": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "unresolved_theorem_ids": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "theorem_ids",
        "theorem_count",
        "all_theorem_ids_resolved",
        "all_theorem_ids_proved",
        "unresolved_theorem_ids",
        "unproved_theorem_ids"
      ],
      "type": "object"
    },
    "receipt_content_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "recommendations": {
      "items": {
        "type": "object"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "request": {
      "additionalProperties": false,
      "oneOf": [
        {
          "properties": {
            "kind": {
              "enum": [
                "rope",
                "rope_position_distinguishability"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "base": {
                  "exclusiveMinimum": 0,
                  "type": "number"
                },
                "context": {
                  "minimum": 1,
                  "type": "integer"
                },
                "discretization": {
                  "enum": [
                    "round",
                    "floor",
                    "ceil"
                  ]
                },
                "head_dim": {
                  "minimum": 2,
                  "multipleOf": 2,
                  "type": "integer"
                },
                "requested_margin": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "tolerance": {
                  "minimum": 0,
                  "type": "number"
                }
              },
              "type": "object"
            }
          }
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "kv",
                "kv-cache",
                "kv_cache",
                "kv_cache_ring_buffer"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "batch_tokens": {
                  "items": {
                    "type": "integer"
                  },
                  "type": "array"
                },
                "cache_size": {
                  "minimum": 1,
                  "type": "integer"
                },
                "current": {
                  "minimum": 0,
                  "type": "integer"
                },
                "request_id": {
                  "minLength": 1,
                  "type": "string"
                },
                "sink_size": {
                  "minimum": 0,
                  "type": "integer"
                },
                "token": {
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "required": [
                "cache_size",
                "current",
                "token"
              ],
              "type": "object"
            }
          }
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "sparse",
                "sparse-attention",
                "sparse_attention",
                "sparse_attention_coverage"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "context": {
                  "minimum": 1,
                  "type": "integer"
                },
                "local_window": {
                  "minimum": 0,
                  "type": "integer"
                },
                "path_length": {
                  "minimum": 0,
                  "type": "integer"
                },
                "strides": {
                  "items": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "minItems": 1,
                  "type": "array"
                }
              },
              "required": [
                "context",
                "strides",
                "path_length",
                "local_window"
              ],
              "type": "object"
            }
          }
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "recurrence",
                "recurrence-schedule",
                "recurrence_schedule"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "loop_period": {
                  "minimum": 1,
                  "type": "integer"
                },
                "max_loops": {
                  "minimum": 1,
                  "type": "integer"
                },
                "sample_index": {
                  "minimum": 0,
                  "type": "integer"
                },
                "selected_block_start": {
                  "minimum": 0,
                  "type": "integer"
                },
                "selected_block_width": {
                  "minimum": 1,
                  "type": "integer"
                },
                "shift_passes": {
                  "minimum": 0,
                  "type": "integer"
                },
                "token_count": {
                  "minimum": 1,
                  "type": "integer"
                }
              },
              "type": "object"
            }
          }
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "fanout",
                "strided-fanout",
                "strided_candidate_fanout"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "context_length": {
                  "minimum": 1,
                  "type": "integer"
                },
                "path_length": {
                  "minimum": 1,
                  "type": "integer"
                },
                "start_index": {
                  "minimum": 0,
                  "type": "integer"
                },
                "stride": {
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "type": "object"
            }
          }
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "cyclic-memory",
                "cyclic_memory",
                "cyclic_memory_residue_winding",
                "memory"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "bank_size": {
                  "minimum": 1,
                  "type": "integer"
                },
                "event_count": {
                  "minimum": 1,
                  "type": "integer"
                },
                "event_index": {
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "type": "object"
            }
          }
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "multicoil-phase",
                "multicoil_phase_feature",
                "phase-feature"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "key_position": {
                  "minimum": 0,
                  "type": "integer"
                },
                "periods": {
                  "items": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "minItems": 1,
                  "type": "array"
                },
                "position": {
                  "minimum": 0,
                  "type": "integer"
                },
                "query_position": {
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "type": "object"
            }
          }
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "circulant-mixer",
                "circulant_block_cyclic_mixer",
                "cyclic-mixer",
                "mixer"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "block_size": {
                  "minimum": 1,
                  "type": "integer"
                },
                "channel_count": {
                  "minimum": 1,
                  "type": "integer"
                },
                "period": {
                  "minimum": 1,
                  "type": "integer"
                }
              },
              "type": "object"
            }
          }
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "seed-rule",
                "seed_rule",
                "seed_rule_exact_regeneration"
              ]
            },
            "parameters": {
              "additionalProperties": false,
              "properties": {
                "n": {
                  "minimum": 1,
                  "type": "integer"
                }
              },
              "type": "object"
            }
          }
        }
      ],
      "properties": {
        "kind": {
          "enum": [
            "circulant-mixer",
            "circulant_block_cyclic_mixer",
            "cyclic-memory",
            "cyclic-mixer",
            "cyclic_memory",
            "cyclic_memory_residue_winding",
            "fanout",
            "kv",
            "kv-cache",
            "kv_cache",
            "kv_cache_ring_buffer",
            "memory",
            "mixer",
            "multicoil-phase",
            "multicoil_phase_feature",
            "phase-feature",
            "recurrence",
            "recurrence-schedule",
            "recurrence_schedule",
            "rope",
            "rope_position_distinguishability",
            "seed-rule",
            "seed_rule",
            "seed_rule_exact_regeneration",
            "sparse",
            "sparse-attention",
            "sparse_attention",
            "sparse_attention_coverage",
            "strided-fanout",
            "strided_candidate_fanout"
          ]
        },
        "parameters": {
          "minProperties": 0,
          "type": "object"
        },
        "schema_id": {
          "const": "circle_calculus.ai_contract_request.v0"
        }
      },
      "required": [
        "schema_id",
        "kind",
        "parameters"
      ],
      "type": "object"
    },
    "request_content_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "request_passed": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "request_schema_id": {
      "const": "circle_calculus.ai_contract_request.v0"
    },
    "schema_id": {
      "const": "circle_calculus.ai_contract_receipt.v0"
    },
    "status": {
      "enum": [
        "proved",
        "impossible",
        "undecided",
        "numerical_only",
        "outside_scope"
      ]
    },
    "support": {
      "type": "object"
    },
    "validation_commands": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schema_id",
    "request_schema_id",
    "contract_pack_schema_id",
    "kind",
    "contract_id",
    "status",
    "request_passed",
    "decision",
    "request",
    "request_content_fingerprint",
    "normalized_request",
    "normalized_request_fingerprint",
    "evidence",
    "proof_status",
    "proof_layers",
    "recommendations",
    "validation_commands",
    "support",
    "not_claimed",
    "content_fingerprint_algorithm",
    "receipt_content_fingerprint"
  ],
  "title": "Circle AI Contract Receipt",
  "type": "object"
}
