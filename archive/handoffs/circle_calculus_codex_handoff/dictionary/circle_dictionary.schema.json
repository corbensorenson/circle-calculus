{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Circle Calculus Dictionary Entry",
  "type": "object",
  "required": [
    "id",
    "name",
    "kind",
    "formal_definition",
    "intuition",
    "dependencies",
    "introduced_in",
    "forbidden_meanings"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CC-[A-Z0-9]+$"
    },
    "name": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "object",
        "operation",
        "relation",
        "proof_rule",
        "theorem",
        "model",
        "warning",
        "paper"
      ]
    },
    "symbol": {
      "type": "string"
    },
    "formal_definition": {
      "type": "string"
    },
    "intuition": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rewrite_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "formal_models": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lean_declarations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "python_objects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "introduced_in": {
      "type": "string"
    },
    "forbidden_meanings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
